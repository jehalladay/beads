#!/usr/bin/env bash
# Pre-commit hook: auto-format with gofmt and lint with golangci-lint.
# Installed via: git config core.hooksPath .githooks
# See also: make install (sets hooksPath automatically)
#
# LINT BINARY RESOLUTION (beads-24k)
# ----------------------------------
# This hook must NOT compile golangci-lint from source on every commit. Doing so
# (`go run …@version`) rebuilds the linter under whatever load the shared crew
# node is under, which OOMs / times out and forces crew to `git commit
# --no-verify` — a gate everyone bypasses is not a gate.
#
# Instead we resolve a PREBUILT, version-PINNED binary (v2.9.0 — the same
# version CI installs; v2.10.x emits phantom findings) in this order:
#   1. `golangci-lint` already on PATH, IF it reports the pinned version
#      (crew nodes symlink the cached /fsx binary into ~/.local/bin — beads-jec).
#   2. $(go env GOPATH)/bin/golangci-lint, IF it reports the pinned version.
#   3. `go install …@<pin>` ONCE into GOPATH/bin (cached; subsequent commits
#      reuse it — no per-commit rebuild), then use that binary.
# If none of these yields a runnable pinned binary (e.g. the toolchain genuinely
# cannot build under load), the hook DEGRADES TO WARN — it prints a loud notice
# and lets the commit proceed rather than forcing --no-verify. CI (make
# ci-pr-lint / pr.yml) remains the HARD gate, so nothing red reaches main.

set -uo pipefail

# The pinned golangci-lint version. Keep in lockstep with the CI install in
# .github/workflows/{pr,main}.yml and ci-measurements.yml.
PINNED_VERSION="v2.9.0"
PINNED_BARE="${PINNED_VERSION#v}"

# Only check staged Go files (Added, Copied, Modified)
staged_go_files=$(git diff --cached --name-only --diff-filter=ACM -- '*.go')
[ -z "$staged_go_files" ] && exit 0

# Auto-format and re-stage (gofmt is cheap and always available).
echo "$staged_go_files" | xargs gofmt -w
echo "$staged_go_files" | xargs git add

# is_pinned <binary> — true if the binary runs and reports PINNED_BARE.
is_pinned() {
    local bin="$1"
    [ -x "$bin" ] || command -v "$bin" >/dev/null 2>&1 || return 1
    "$bin" --version 2>/dev/null | grep -q "version ${PINNED_BARE}\b"
}

# Resolve a runnable, pinned golangci-lint binary; echo its path, or nothing.
resolve_linter() {
    # 1. On PATH at the pinned version.
    if command -v golangci-lint >/dev/null 2>&1 && is_pinned golangci-lint; then
        command -v golangci-lint
        return 0
    fi
    # 2. GOPATH/bin at the pinned version.
    local gobin
    gobin="$(go env GOPATH 2>/dev/null)/bin/golangci-lint"
    if is_pinned "$gobin"; then
        printf '%s\n' "$gobin"
        return 0
    fi
    # 3. Install the pinned version once (cached in GOPATH/bin + build cache).
    #    This builds ONCE; every later commit hits path 1/2 and never rebuilds.
    echo "pre-commit: installing golangci-lint ${PINNED_VERSION} (one-time; cached for future commits)…" >&2
    if go install "github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${PINNED_VERSION}" >&2 2>&1; then
        if is_pinned "$gobin"; then
            printf '%s\n' "$gobin"
            return 0
        fi
    fi
    return 1
}

LINTER="$(resolve_linter || true)"

if [ -z "$LINTER" ]; then
    # Degrade to warn (beads-24k fallback 2): could not obtain the pinned linter
    # — do NOT force the developer to --no-verify. CI is the hard gate.
    cat >&2 <<EOF
⚠️  pre-commit: could not obtain golangci-lint ${PINNED_VERSION} (toolchain build
    failed or unavailable). Skipping the local lint step for THIS commit.
    Your commit is NOT blocked, but CI (make ci-pr-lint) will still enforce lint —
    fix any findings before the merge queue picks this up.
    To restore the local gate, ensure golangci-lint ${PINNED_VERSION} is on PATH
    (crew nodes: symlink the cached /fsx binary into ~/.local/bin — see beads-jec).
EOF
    exit 0
fi

# Lint changed code with auto-fix; block on remaining issues.
# CGO_ENABLED=0 avoids typecheck failures from CGO-only dependencies
# (e.g., dolthub/go-icu-regex) that require system headers not always present.
#
# SERIALIZATION under concurrent-commit load (beads-qre, follow-up to beads-ub3):
# golangci-lint takes a HARDCODED global lock at /tmp/golangci-lint.lock (shared
# across all crew on a node). --allow-serial-runners makes it WAIT for that lock
# instead of erroring out — but golangci counts the wait against its OWN
# analysis --timeout, so under load a queued run's timeout elapses while it is
# still blocked on the lock and the commit is rejected even though no analysis
# ran (pushing crew back to --no-verify). We fix that by taking OUR OWN flock
# with a BOUNDED wait BEFORE invoking the linter, so the lock-wait is outside
# golangci's timeout budget. We still pass --allow-serial-runners as a
# belt-and-suspenders guard against golangci's own lock.
#
# If the bounded wait is exceeded (a sibling sweep held the lock too long), we
# DEGRADE-TO-WARN and let the commit proceed rather than forcing --no-verify —
# the same philosophy as the "couldn't obtain the pinned linter" fallback above.
# CI (make ci-pr-lint) remains the hard gate, so nothing red reaches main.
#
# Knobs: BEADS_PRECOMMIT_LINT_LOCK (lock path; "" disables the flock wrapper),
# BEADS_PRECOMMIT_LINT_LOCK_WAIT (bounded wait in seconds, default 120).
LINT_LOCK="${BEADS_PRECOMMIT_LINT_LOCK-/tmp/golangci-lint.lock}"
LINT_LOCK_WAIT="${BEADS_PRECOMMIT_LINT_LOCK_WAIT:-120}"

run_linter() {
    CGO_ENABLED=0 "$LINTER" run --new-from-rev=HEAD --allow-serial-runners --fix
}

lint_rc=0
if [ -n "$LINT_LOCK" ] && command -v flock >/dev/null 2>&1; then
    # -w bounds the wait OUTSIDE golangci's timeout; -E 75 marks "lock not
    # acquired in time" distinctly from a real lint failure. flock runs
    # run_linter (exported below) once the lock is held.
    export LINTER
    flock -w "$LINT_LOCK_WAIT" -E 75 "$LINT_LOCK" \
        bash -c "$(declare -f run_linter); run_linter"
    lint_rc=$?
    if [ "$lint_rc" -eq 75 ]; then
        cat >&2 <<EOF
⚠️  pre-commit: golangci-lint's global lock was held by a concurrent run for
    more than ${LINT_LOCK_WAIT}s (shared-node contention). Skipping the local
    lint step for THIS commit rather than blocking you — CI (make ci-pr-lint)
    will still enforce lint before the merge queue picks this up (beads-qre).
EOF
        lint_rc=0
    fi
else
    run_linter
    lint_rc=$?
fi

[ "$lint_rc" -eq 0 ] || exit 1

# Re-stage any auto-fixes from the linter
echo "$staged_go_files" | xargs git add
